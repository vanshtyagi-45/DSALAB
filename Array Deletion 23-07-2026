#include<stdio.h>
int main(){
    int a[100],n,pos,i;
    printf("Enter the array element: ");
    scanf("%d",&n);
    printf("Enter the array element: ");
    for(i=0;i<n;i++){
        scanf("%d",&a[i]);
    }
    printf("Enter the position(o to %d): ",n);
    scanf("%d",&pos);
    if(pos<1 || pos>n){
        printf("Invalid position!\n");

    }else{
        for(i=pos-1;i<n-1;i++){
            a[i]=a[i+1];

        }
        n--;
        printf("Array after deletion:\n");
        for(i=0;i<n;i++){
            printf("%d",a[i]);
        }
    }
    return 0;
