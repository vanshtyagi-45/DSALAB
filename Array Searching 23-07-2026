#include<stdio.h>
int main(){
    int a[100],n,key,i,found=0;
    printf("Enter the array element: ");
    scanf("%d",&n);
    printf("Enter the array element: ");
    for(i=0;i<n;i++){
        scanf("%d",&a[i]);
    }
    printf("Enter the element to search: ");
    scanf("%d",&key);
    for(i=0;i<n;i++){
        if(a[i]==key){
            printf("Element found at position %d",i+1);
            found=1;
            break;
        }
    }
    if(found==0){
        printf("Element not found");
    }
    return 0;
}
