#include<stdio.h>
int main(){
    int arr1[50],arr2[70],arr3[100],n1,n2,i,j;
    printf("Enter the first array size: ");
    scanf("%d",&n1);
    printf("Enter the element of first array:\n");
    for(i=0;i<n1;i++){
        scanf("%d",&arr1[i]);
    }
    printf("Enter the second array size: ");
    scanf("%d",&n1);
    printf("Enter the element of second array:\n");
    for(i=0;i<n2;i++){
        scanf("%d",&arr2[i]);
    }
    for(i=0;i<n1;i++){
        arr3[j]=arr2[i];
    }
    printf("Merged array:\n");
    for(i=0;i<n1+n2;i++){
        printf("%d",arr3[i]);
    }
    return 0;
}
